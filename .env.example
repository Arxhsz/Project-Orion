# Optional local-only configuration for Project Orion.
# Do not commit real credentials.

# Cesium ion is only needed for optional OSM Buildings / terrain features.
CESIUM_ION_TOKEN=

# OpenSky now recommends OAuth client credentials for programmatic API access.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Optional licensed AIS provider credentials. Keep server-side only.
AIS_PROVIDER=
AIS_API_KEY=

# Local server CORS. Use explicit production origins if deployed behind a backend.
ORION_ALLOWED_ORIGINS=http://127.0.0.1:4174,http://localhost:4174

# Set to 1 only when intentionally building demo/static fallback intel snapshots.
ORION_SYNTHETIC_INTEL=0
